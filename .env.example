# ===== Django =====
DJANGO_SECRET_KEY=change-me-generate-with-secrets
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=chronoq.settings.dev

# ===== Postgres =====
POSTGRES_DB=chronoq
POSTGRES_USER=chronoq
POSTGRES_PASSWORD=chronoq_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== Frontend =====
VITE_API_BASE_URL=http://localhost:8000/api
